# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env before running: docker compose up --build
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME=Immobilier
APP_ENV=production
APP_KEY=base64:MHRblMpwUerT3qzsPsjuFGujQ3ukS0QEDrw7tJo/8po=
APP_DEBUG=false
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── Database (resolved to the postgres container) ────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=immobilier
DB_USERNAME=postgres
DB_PASSWORD=secret

# ── Cache & Session – use database (no extra services needed) ─────────────────
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Queue ─────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=database

# ── Octane ────────────────────────────────────────────────────────────────────
OCTANE_SERVER=roadrunner

# ── Filesystem – MinIO S3 ────────────────────────────────────────────────────
FILESYSTEM_DISK=s3
MEDIA_DISK=s3

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=immobilier
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
# Public URL used to build media URLs returned in API responses.
# Point this to the MinIO bucket URL accessible from outside Docker.
AWS_URL=http://localhost:9000/immobilier

# ── MeiliSearch ───────────────────────────────────────────────────────────────
SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=changeme_master_key_32chars_min!

# ── Mail (log driver – swap for real SMTP in production) ─────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Broadcast ─────────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ── MinIO console + nginx ports (docker-compose.yml reads these) ──────────────
NGINX_PORT=8080
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

VITE_APP_NAME="${APP_NAME}"
